# --- Vite (exposed to the browser — no secrets) ---
VITE_AI_PROVIDER=together
VITE_EMBEDDINGS_PROVIDER=voyage
VITE_RERANK_PROVIDER=voyage
VITE_AI_MODEL_NAME=meta-llama/Meta-Llama-3.1-70B-Instruct-Turbo
VITE_EMBEDDINGS_MODEL_NAME=voyage-3-large
VITE_RERANK_MODEL_NAME=rerank-2.5-lite
VITE_VECTOR_STORE_PROVIDER=memory
# Optional: absolute base for `/api/ai/*` when not same-origin (production gateway).
VITE_AI_HTTP_BASE=

# --- Server-only (`npm run dev` / `vite` loads these for `vite.quiloraAiProxy.ts`) ---
AI_API_KEY=
EMBEDDINGS_API_KEY=
RERANK_API_KEY=

# Same model names for server-side scripts / docs (Vite client uses VITE_* above).
AI_MODEL_NAME=meta-llama/Meta-Llama-3.1-70B-Instruct-Turbo
EMBEDDINGS_MODEL_NAME=voyage-3-large
RERANK_MODEL_NAME=rerank-2.5-lite

# --- Optional persistence (workers) ---
DATABASE_URL=

# --- Existing Quilora ---
# VITE_DEEPSEEK_API_KEY=
# DEEPSEEK_API_KEY=

# --- Polar billing (Quilora) ---
# Search in repo: TODO_POLAR_MANUAL_SETUP | see src/lib/billing/polarManualSetup.ts
#
# --- A) Client-safe (Vite — paste into .env.local or hosting env) ---
# TODO_APP_URL — Must match the browser origin users use (affects checkout success/cancel URLs).
VITE_APP_URL=https://localhost:3000
# TODO_POLAR_ENV — sandbox | production (informational on client; Edge uses POLAR_ENV below).
VITE_POLAR_ENV=production

# --- B) Server-only — Supabase Dashboard → Project → Edge Functions → Secrets (NOT in Vite bundle) ---
# TODO_POLAR_ACCESS_TOKEN — Polar → Organization → Access tokens (OAT). Used by polar_api.ts + billing_adjustments.ts
POLAR_ACCESS_TOKEN=
# TODO_POLAR_WEBHOOK_SECRET — Polar → Webhooks → your endpoint → Signing secret. Used by polar_billing.ts verifyPolarWebhook
POLAR_WEBHOOK_SECRET=
# TODO_POLAR_ENV — production | sandbox (selects api.polar.sh vs sandbox-api.polar.sh when POLAR_API_BASE unset)
POLAR_ENV=production
# TODO_POLAR_API_BASE — Optional override, e.g. https://api.polar.sh or https://sandbox-api.polar.sh
# POLAR_API_BASE=https://api.polar.sh

# TODO_POLAR_PRODUCT_* — Polar → Products → each plan’s Product ID (UUID). Mapped in src/supabase/functions/server/polar_plan.ts
POLAR_PRODUCT_BOOKWORM_MONTHLY=
POLAR_PRODUCT_BOOKWORM_YEARLY=
POLAR_PRODUCT_SAGE_MONTHLY=
POLAR_PRODUCT_SAGE_YEARLY=
POLAR_PRODUCT_GENESIS_LIFETIME=
# TODO_POLAR_PRODUCT_BOOST_PACK — Optional Boost Pack product UUID
# POLAR_PRODUCT_BOOST_PACK=
