# --- Local dev: skip manual login (optional) ---
# 1) Create a user: `npm run create-test-user` (or node scripts/create-test-user.mjs)
# 2) In Supabase Dashboard → Authentication → Users: confirm email for that user, OR disable "Confirm email".
# 3) Copy the lines below into `.env.local` with the same email/password (never commit `.env.local`).
# VITE_DEV_AUTO_LOGIN=true
# VITE_DEV_TEST_EMAIL=quilora.local.test@example.com
# VITE_DEV_TEST_PASSWORD=TestQuilora9A

# --- Vite (exposed to the browser — no secrets) ---
# Vite exposes `VITE_*` and `NEXT_PUBLIC_*` (see vite.config.ts envPrefix).
VITE_AI_PROVIDER=together
VITE_EMBEDDINGS_PROVIDER=voyage
VITE_RERANK_PROVIDER=voyage
VITE_AI_MODEL_NAME=meta-llama/Meta-Llama-3.1-70B-Instruct-Turbo
VITE_EMBEDDINGS_MODEL_NAME=voyage-3-large
VITE_RERANK_MODEL_NAME=rerank-2.5-lite
VITE_VECTOR_STORE_PROVIDER=memory
VITE_AI_HTTP_BASE=

# --- Server-only (`npm run dev` / `vite` loads these for `vite.quiloraAiProxy.ts`) ---
AI_API_KEY=
EMBEDDINGS_API_KEY=
RERANK_API_KEY=

AI_MODEL_NAME=meta-llama/Meta-Llama-3.1-70B-Instruct-Turbo
EMBEDDINGS_MODEL_NAME=voyage-3-large
RERANK_MODEL_NAME=rerank-2.5-lite

DATABASE_URL=

# VITE_DEEPSEEK_API_KEY=
# DEEPSEEK_API_KEY=

# --- Dodo Payments ---
# Supabase Edge + optional Next.js webhook (never expose API key on the client).
DODO_PAYMENTS_API_KEY=
# Optional override; otherwise Edge uses NODE_ENV (production → live API host).
DODO_PAYMENTS_ENVIRONMENT=test_mode
DODO_PAYMENTS_WEBHOOK_SECRET=
PUBLIC_APP_URL=https://www.quilora.app
# Checkout Session redirect after payment (Dodo `return_url`).
DODO_CHECKOUT_RETURN_URL=https://www.quilora.app/billing/success
# Leave unset to use server default `/early-access` (pre-launch pricing). Override only if needed.
DODO_CHECKOUT_CANCEL_URL=

# Dodo product / price IDs for overlay checkout (safe in the browser).
NEXT_PUBLIC_PRICE_ID_BOOKWORM_MONTHLY=
NEXT_PUBLIC_PRICE_ID_BOOKWORM_YEARLY=
NEXT_PUBLIC_PRICE_ID_SAGE_MONTHLY=
NEXT_PUBLIC_PRICE_ID_SAGE_YEARLY=
NEXT_PUBLIC_PRICE_ID_LIFETIME_EARLY_BIRD=
NEXT_PUBLIC_PRICE_ID_LIFETIME_STANDARD=
NEXT_PUBLIC_PRICE_ID_LIFETIME_PLUS_SAGE=

# Optional: legacy Vite-only names (fallback if NEXT_PUBLIC_* unset)
VITE_DODO_PRODUCT_BOOKWORM_MONTHLY=
VITE_DODO_PRODUCT_BOOKWORM_YEARLY=
VITE_DODO_PRODUCT_BIBLIOPHILE_MONTHLY=
VITE_DODO_PRODUCT_BIBLIOPHILE_YEARLY=
VITE_DODO_PRODUCT_GENESIS_80=
VITE_DODO_PRODUCT_GENESIS_119=
VITE_DODO_PRODUCT_BOOST_PACK=
VITE_DODO_PRODUCT_TOKENS_SMALL=
VITE_DODO_PRODUCT_TOKENS_MEDIUM=
VITE_DODO_PRODUCT_TOKENS_LARGE=

# --- Next.js webhook route (`app/api/webhooks/dodo/route.ts`) ---
NEXT_PUBLIC_SUPABASE_URL=
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
QUILORA_WEBHOOK_APPLY_URL=

# --- Vercel cron → Edge reconcile (6h, paid-but-not-signed-up recovery) ---
QUILORA_CRON_RECONCILE_URL=
CRON_SECRET=
